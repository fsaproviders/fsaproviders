# =============================================================================
# WordPress core — never tracked
# =============================================================================
/wp-admin/
/wp-includes/
/wp-*.php
/index.php
/xmlrpc.php
/license.txt
/readme.html

# =============================================================================
# Config & secrets — never tracked
# =============================================================================
wp-config.php
wp-config-*.php
.env
.env.*
.htaccess
.user.ini

# =============================================================================
# Runtime content — never tracked
# =============================================================================
wp-content/uploads/
wp-content/cache/
wp-content/upgrade/
wp-content/backup*/
wp-content/wflogs/
wp-content/debug.log
wp-content/*.log
wp-content/advanced-cache.php
wp-content/object-cache.php
wp-content/db.php

# =============================================================================
# Themes — parent and defaults stay out, child theme gets tracked
# =============================================================================
wp-content/themes/*
!wp-content/themes/mylisting-child/
!wp-content/themes/index.php
# =============================================================================
# wp-content runtime / auto-generated content — never tracked
# =============================================================================
wp-content/index.php
wp-content/ai1wm-backups/
wp-content/jetpack-waf/
wp-content/languages/
wp-content/mu-plugins/
wp-content/blogs.dir/
wp-content/upgrade-temp-backup/
wp-content/et-cache/
wp-content/wflogs/
wp-content/updraft/
wp-content/wmufs-temp/
wp-content/wp-rocket-config/

# =============================================================================
# Plugins — third-party out, only our custom plugins tracked
# Add new custom plugins here with a leading "!"
# =============================================================================
wp-content/plugins/*
!wp-content/plugins/fsa-account-menu-manager/
!wp-content/plugins/fsa-identity-card/
!wp-content/plugins/fsa-discount-panel-v2/
!wp-content/plugins/fsahsa-sync/
!wp-content/plugins/index.php

# =============================================================================
# OS / editor
# =============================================================================
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
*~

# =============================================================================
# Build artifacts / dependencies (if you add build tooling later)
# =============================================================================
node_modules/
vendor/
composer.lock
package-lock.json
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# =============================================================================
# Misc
# =============================================================================
*.zip
*.tar.gz
*.sql
!docs/**/*.sql
# =============================================================================
# Legacy host artifacts (Bluehost/GoDaddy/cPanel migration leftovers)
# =============================================================================
404.shtml
googlecloud.html
home.html
index.html
layout-styles.css
error_log
.tmb/
.well-known/
imagify-backup/
local-xdebuginfo.php
demo.fsaproviders.com/
